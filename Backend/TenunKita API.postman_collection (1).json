        }
      ]
    },
    {
      "name": "📩 Contacts",
      "description": "Endpoint pesan kontak - kirim pesan publik dan manajemen admin",
      "item": [
        {
          "name": "Kirim Pesan Kontak (Publik)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/contacts", "host": ["{{baseUrl}}"], "path": ["contacts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Siti Rahayu\",\n  \"email\": \"siti@example.com\",\n  \"phone\": \"081234567890\",\n  \"message\": \"Halo, saya ingin bertanya tentang produk kain tenun.\"\n}"
            }
          }
        },
        {
          "name": "[ADMIN] Lihat Semua Pesan Kontak",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/contacts", "host": ["{{baseUrl}}"], "path": ["contacts"] }
          }
        },
        {
          "name": "[ADMIN] Lihat Pesan by ID",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/contacts/1", "host": ["{{baseUrl}}"], "path": ["contacts", "1"] }
          }
        },
        {
          "name": "[ADMIN] Update Status Pesan Kontak",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },

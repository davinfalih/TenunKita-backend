            "url": { "raw": "{{baseUrl}}/payment/bill/1", "host": ["{{baseUrl}}"], "path": ["payment", "bill", "1"] }
          }
        },
        {
          "name": "[ADMIN] Verifikasi Pembayaran",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/payment/verify/1", "host": ["{{baseUrl}}"], "path": ["payment", "verify", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\",\n  \"adminNote\": \"Pembayaran telah dikonfirmasi.\"\n}"
            }
          }
        },
        {
          "name": "[ADMIN] Hapus Pembayaran",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/payment/1", "host": ["{{baseUrl}}"], "path": ["payment", "1"] }
          }
        }
      ]
    },
    {
      "name": "⭐ Ratings",

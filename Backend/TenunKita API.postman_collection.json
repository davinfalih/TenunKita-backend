{
  "info": {
    "_postman_id": "tenunkita-collection-v2",
    "name": "TenunKita API",
    "description": "Koleksi API lengkap untuk proyek E-Commerce TenunKita.\n\n**Cara pakai:**\n1. Import file ini ke Postman\n2. Import juga salah satu environment (Local atau Production Railway)\n3. Pilih environment yang sesuai dari dropdown pojok kanan atas\n4. Jalankan **Login** terlebih dahulu — `authToken` akan tersimpan otomatis\n5. Semua endpoint lain akan langsung bisa digunakan\n\n**Base URL:**\n- Local: http://localhost:3000\n- Production: https://tenunkita-production.up.railway.app",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Budi Santoso\",\n  \"email\": \"budi@email.com\",\n  \"password\": \"password123\",\n  \"address\": \"Jl. Merdeka No. 1, Jakarta\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Daftarkan user baru dengan role BUYER (default)"
          },
          "response": []
        },
        {
          "name": "Register Admin",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin TenunKita\",\n  \"email\": \"admin@tenunkita.com\",\n  \"password\": \"admin123\",\n  \"address\": \"Kantor Pusat TenunKita\",\n  \"adminSecret\": \"AdminSecret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register-admin",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register-admin"]
            },
            "description": "Daftarkan admin baru (butuh adminSecret yang benar)"
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('authToken', jsonData.access_token);",
                  "  pm.environment.set('userId', jsonData.user ? jsonData.user.id : '');",
                  "  console.log('Token tersimpan:', jsonData.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"budi@email.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login dan dapatkan JWT token. Token akan otomatis tersimpan ke variabel `authToken`."
          },
          "response": []
        }
      ]
    },

                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('productId', jsonData.id);",
                  "  console.log('productId tersimpan:', jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Kain Tenun Ikat NTT", "type": "text" },
                { "key": "description", "value": "Kain tenun tradisional dari Nusa Tenggara Timur", "type": "text" },
                { "key": "price", "value": "250000", "type": "text" },
                { "key": "stock", "value": "50", "type": "text" },
                { "key": "categoryId", "value": "{{categoryId}}", "type": "text" },
                { "key": "image", "type": "file", "src": "", "description": "Upload gambar produk (opsional)" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            },
            "description": "Gunakan form-data karena ada upload gambar. Field `image` bisa dikosongkan."
          },
          "response": []
        },

              "query": [
                { "key": "search", "value": "", "disabled": true, "description": "Cari produk berdasarkan nama" },
                { "key": "categoryId", "value": "", "disabled": true, "description": "Filter berdasarkan kategori" }
              ]
            },
            "description": "Publik - tidak perlu login. Bisa filter dengan ?search=nama&categoryId=1"
          },
          "response": []
